# Copy to .env and fill in. docker-compose reads from .env at the repo root
# and propagates these into the gateway container.

# ─── Database / app ───────────────────────────────────────────────────────────
DATABASE_URL=postgres://dexter:dexter@db:5432/dexter
LOG_LEVEL=INFO
AUTO_SEED=true

# ─── LLM provider keys ────────────────────────────────────────────────────────
# Replicate API token — LiteLLM picks this up automatically when a model
# string starts with `replicate/`. Get one at https://replicate.com/account
REPLICATE_API_TOKEN=

# Add others as you adopt them. LiteLLM reads provider keys by convention:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# ─── LLM model routing (per role, primary + fallback) ─────────────────────────
# Any LiteLLM-supported model string. Defaults below assume Replicate hosts
# these slugs — verify against your Replicate account and edit if different.
# Switching providers later is one line each: `replicate/...` → `anthropic/...`
# or `openai/...` etc.
DEXTER_LLM_PLANNER=replicate/anthropic/claude-4.5-sonnet
DEXTER_LLM_PLANNER_FALLBACK=replicate/openai/gpt-4o-mini

DEXTER_LLM_EXTRACTOR=replicate/anthropic/claude-4.5-sonnet
DEXTER_LLM_EXTRACTOR_FALLBACK=replicate/openai/gpt-4o

DEXTER_LLM_JUDGE=replicate/anthropic/claude-4.5-haiku
DEXTER_LLM_JUDGE_FALLBACK=replicate/openai/gpt-4o-mini

# ─── Observability — LangFuse ─────────────────────────────────────────────────
# Free tier at https://cloud.langfuse.com (50k events/month). Sign up, create
# a project, copy the public + secret keys. With both set, every LiteLLM call
# automatically ships to LangFuse with request_id as the trace_id — opens up
# the per-step debugger UI. Leave keys blank to skip silently.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── LLM reliability knobs (optional — defaults shown) ────────────────────────
# DEXTER_LLM_REQUEST_TIMEOUT_S=20
# DEXTER_LLM_NUM_RETRIES=3
# DEXTER_LLM_BREAKER_FAILURE_THRESHOLD=3
# DEXTER_LLM_BREAKER_WINDOW_SECONDS=60
# DEXTER_LLM_BREAKER_COOLDOWN_SECONDS=300
# DEXTER_LLM_DEFAULT_TEMPERATURE=0.0
# DEXTER_LLM_DEFAULT_MAX_TOKENS=1024
